# dia — omgevingsvariabelen (kopieer naar .env; .env staat in .gitignore en wordt NOOIT gecommit)

# Hugging Face-token: alleen nodig voor het gated pyannote-model
# (huggingface.co → Settings → Access Tokens; accepteer ook de voorwaarden op de modelpagina)
HF_TOKEN=

# Samenvattings-LLM (OpenAI-compatibel). Leeg laten = de app detecteert automatisch
# een lokaal draaiend endpoint (Instellingen → "Automatisch detecteren").
SUMMARIZER_URL=
SUMMARIZER_MODEL=

# Optioneel: LoRA-adapter voor de definitieve versie (vergt CGN-licentie; zie README).
# Leeg of niet-bestaand pad = automatisch het vrije basismodel.
REFINE_ADAPTER=models/lora/M2-cgn

# Alleen nodig voor scripts/download_cgn.sh (persoonlijke INT-leverlink na licentie):
CGN_PCLOUD_CODE=
CGN_PCLOUD_FILEID=
